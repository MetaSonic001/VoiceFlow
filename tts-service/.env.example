# ──────────────────────────────────────────────────────────
# VoiceFlow — Chatterbox TTS Service (.env)
# Copy this file to .env and fill in real values.
# ──────────────────────────────────────────────────────────

# MinIO (stores TTS cache and voice profile audio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=voiceflow-tts
MINIO_USE_SSL=false

# Device for model inference (cuda for GPU, cpu for CPU-only)
DEVICE=cuda
