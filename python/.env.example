# ═══════════════════════════════════════════════════════════════════
# VoiceFlow — Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ─── Database (Postgres via Docker on port 8010) ──────────────────
DATABASE_URL=postgresql+asyncpg://vf_admin:vf_secure_2025!@localhost:8010/voiceflow_prod
DB_NAME=voiceflow_prod
DB_USER=vf_admin
DB_PASSWORD=vf_secure_2025!
DB_HOST=localhost
DB_PORT=8010

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=8020

# ─── ChromaDB ─────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8030

# ─── AI / LLM (Groq) — REQUIRED for default provider ─────────────
# Get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional additional LLM providers
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Supported providers (comma-separated) and default
SUPPORTED_LLMS=groq,openai,gemini,ollama
DEFAULT_LLM=groq

# ─── TTS ──────────────────────────────────────────────────────────
KOKORO_TTS_URL=http://localhost:8880
PIPER_TTS_URL=http://localhost:8890
ORPHEUS_URL=http://localhost:8080

# ─── STT ──────────────────────────────────────────────────────────
VOSK_MODEL_PATH=./models/vosk-model-small-en-us-0.15
STT_ENGINE=faster-whisper

# ─── Audio ────────────────────────────────────────────────────────
AUDIO_PROCESSOR=pydub

# ─── Services ─────────────────────────────────────────────────────
BACKEND_API_URL=http://localhost:8040

# ─── MinIO (S3-compatible object storage) ─────────────────────────
MINIO_ENDPOINT=localhost:9020
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=voiceflow-tts

# ─── Backend Server ──────────────────────────────────────────────
PORT=8040
JWT_SECRET=change-this-to-a-random-string-in-production

# ─── Credential Encryption (Claim 9) ─────────────────────────────
# 64-char hex string (32 bytes). Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# If not set, a dev-only fallback key is used (NOT secure for production)
CREDENTIALS_ENCRYPTION_KEY=

# ─── Twilio (optional — for voice calls, Claim 8) ────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WEBHOOK_BASE_URL=https://your-domain.ngrok-free.app

