# ═══════════════════════════════════════════════════════════════════
# VoiceFlow — Environment Configuration
# Copy to .env and fill in your values:  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ─── Database (Postgres via Docker on port 5433) ──────────────────
DATABASE_URL=postgresql+asyncpg://vf_admin:vf_secure_2025!@localhost:5433/voiceflow_prod
DB_NAME=voiceflow_prod
DB_USER=vf_admin
DB_PASSWORD=vf_secure_2025!
DB_HOST=localhost
DB_PORT=5433

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── ChromaDB ─────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8002

# ─── AI / LLM (Groq) — REQUIRED ──────────────────────────────────
# Get your free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# ─── Services ─────────────────────────────────────────────────────
TTS_SERVICE_URL=http://localhost:8003
BACKEND_API_URL=http://localhost:8000

# ─── MinIO (S3-compatible object storage) ─────────────────────────
MINIO_ENDPOINT=localhost:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=voiceflow-tts

# ─── Backend Server ──────────────────────────────────────────────
PORT=8000
JWT_SECRET=change-this-to-a-random-string-in-production
