# ──────────────────────────────────────────────────────────
# VoiceFlow — Express Backend (.env)
# Copy this file to .env and fill in real values.
# ──────────────────────────────────────────────────────────

# ─── Required ─────────────────────────────────────────────

# PostgreSQL (matches docker-compose defaults)
DATABASE_URL=postgresql://vf_admin:vf_secure_2025!@localhost:5433/voiceflow_prod

# JWT secret for token signing (change in production)
JWT_SECRET=dev-secret

# Groq LLM — platform fallback key
# Get key from https://console.groq.com
# Each tenant can enter their own Groq key in Settings → Integrations.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Services ─────────────────────────────────────────────

FASTAPI_URL=http://localhost:8001
TTS_SERVICE_URL=http://localhost:8003

# ─── MinIO (S3-compatible file storage) ───────────────────

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# ─── Server ───────────────────────────────────────────────

PORT=8000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ─── Optional ─────────────────────────────────────────────
# Uncomment and fill in only if you need these features.

# ChromaDB (defaults to http://localhost:8002)
# CHROMA_URL=http://localhost:8002

# Redis (defaults to localhost:6379 if omitted)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Twilio (only needed for voice/phone features)
# Each tenant can enter their own keys in Settings → Integrations.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app

# Credential encryption (for storing tenant Twilio creds)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CREDENTIALS_ENCRYPTION_KEY=

# ngrok (for Twilio webhooks during local dev)
# NGROK_URL=your-subdomain.ngrok.io
